# briefing.env — sourced by cron_briefing.sh. Define variables only.
# Copy to briefing.env and fill in your own values (briefing.env is gitignored).
#
#   NOTIFY_CHANNEL : telegram | whatsapp
#   NOTIFY_TARGET  : Telegram chat id (e.g. 123456789)
#                    or WhatsApp number (e.g. +62XXXXXXXXXX).
# Leave NOTIFY_TARGET empty to fall back to WhatsApp -> owner.

NOTIFY_CHANNEL="telegram"
NOTIFY_TARGET=""
